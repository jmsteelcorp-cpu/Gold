generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  contactHash   String
  createdAt     DateTime       @default(now())
  applications  Application[]
  notifications Notification[]
}

model Agent {
  id              String   @id @default(cuid())
  agentNo         String   @unique
  agentName       String
  contact         String?
  commissionType  String // percentage | flat
  commissionValue Float
  active          Boolean  @default(true)
  uses            Int      @default(0)
  earnings        Float    @default(0)
  totalPaid       Float    @default(0)
  payoutStatus    String   @default("unpaid")
  createdAt       DateTime @default(now())
}

model Application {
  id            String     @id @default(cuid())
  invoiceNo     String     @unique
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  type          String // investor | dependent | valuation
  ownership     String?
  ocrJson       String? // extracted OCR fields, JSON
  depsJson      String     @default("[]") // dependents [{relation}]
  sponsorJO     String?
  propertyJson  String? // valuation property details, JSON
  amount        Float
  billingName   String?
  agentCode     String?
  commission    Float      @default(0)
  paymentMethod String?
  status        String     @default("invoice_created") // invoice_created | link_sent | paid
  paymentLink   String?
  createdAt     DateTime   @default(now())
  jobOrders     JobOrder[]
}

model JobOrder {
  id              String     @id @default(cuid())
  jobOrderNumber  String     @unique
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id])
  kind            String // visa | valuation
  holderName      String
  relationship    String?
  amount          Float
  docPhase        String     @default("awaiting_upload") // awaiting_upload | submitted | needs_reupload | verified
  dld             String     @default("pending") // pending | applied | approved
  gdrfa           String     @default("pending")
  medical         String     @default("pending") // pending | scheduled | completed
  medicalDate     String?
  biometric       String     @default("pending")
  biometricDate   String?
  emiratesId      String     @default("not_started") // not_started | printing | courier
  taskStatus      String     @default("in_progress") // in_progress | completed
  valuationStage  String? // received | assessment | report_prep | ready
  reportValue     Float?
  reportNotes     String?
  slaDays         Int        @default(15)
  historyJson     String     @default("[]")
  createdAt       DateTime   @default(now())
  documents       Document[]
}

model Document {
  id           String   @id @default(cuid())
  jobOrderId   String
  jobOrder     JobOrder @relation(fields: [jobOrderId], references: [id])
  type         String
  status       String   @default("not_uploaded") // not_uploaded | uploaded | verified | rejected
  ocrConfirmed Boolean  @default(false)
  fileName     String?
  fileData     String? // data URI (base64) — see README "File storage" row for swapping to S3/R2
  comment      String?
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LedgerEntry {
  id        String   @id @default(cuid())
  type      String // payment | commission
  label     String
  ref       String
  amount    Float
  createdAt DateTime @default(now())
}
