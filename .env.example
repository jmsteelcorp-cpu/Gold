# Postgres connection string (Supabase, Neon, or Vercel Postgres all work)
DATABASE_URL="postgresql://user:password@host:5432/golden_pass?schema=public"

# Random long string used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-string"

# Admin login (single staff account for the prototype — replace with real staff auth before launch)
ADMIN_EMAIL="admin@goldenpass.ae"
ADMIN_PASSWORD="change-this-password"

# Base URL used in outgoing email links (your production domain once deployed)
APP_URL="http://localhost:3000"

# Optional: transactional email (Resend). Leave blank to keep in-app-only
# notifications — every status update already routes through this once set.
# 1. Create a Resend account, verify your sending domain.
# 2. Set RESEND_API_KEY and EMAIL_FROM below.
RESEND_API_KEY=""
EMAIL_FROM="Golden Pass <notifications@yourdomain.com>"

# Optional: Stripe test-mode integration for card payments on the payment page.
# Leave blank to keep the manual payment-link flow (admin pastes a link, confirms once paid).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Optional: file storage (S3-compatible). Leave blank to keep the simulated/local upload flow.
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION=""

# Optional: real OCR (AWS Textract). Leave blank to keep the simulated OCR extraction.
AWS_TEXTRACT_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
